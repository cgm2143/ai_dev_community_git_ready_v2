NODE_ENV=development
PORT=3000
API_PREFIX=v1

DATABASE_URL=postgresql://devuser:devpassword@postgres:5432/ai_dev_community?schema=public

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Railway/Render 등 PaaS에서 Redis를 단일 연결 문자열로 제공하는 경우, 위 3개 대신
# 이 값 하나만 설정해도 된다 (예: redis://default:password@host:6379). 설정되어 있으면 이 값이 우선한다.
# REDIS_URL=

# BullMQ(메일 큐) 전용 Redis 커넥션. 비워두면 위 REDIS_* 값을 그대로 사용(같은 인스턴스, 별도 커넥션).
# 운영 규모가 커지면 이 값들만 채워서 큐 전용 Redis 인스턴스로 분리할 수 있다.
QUEUE_REDIS_HOST=
QUEUE_REDIS_PORT=
QUEUE_REDIS_PASSWORD=

# openssl rand -base64 48 등으로 생성한 32자 이상의 값을 사용할 것. Access/Refresh는 반드시 다른 값이어야 한다.
JWT_ACCESS_SECRET=replace-with-32-plus-character-random-secret-for-access
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-different-32-plus-character-random-secret
JWT_REFRESH_EXPIRES_IN=14d

CORS_ORIGIN=http://localhost:3001
FRONTEND_URL=http://localhost:3001

MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=apikey
MAIL_PASSWORD=replace-with-smtp-password
MAIL_FROM=devhub <no-reply@devhub.example.com>
MAIL_SECURE=false

# S3 호환 스토리지 (프로필 이미지, 게시글 첨부파일 등). 로컬 개발은 MinIO 등으로 대체 가능.
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=ai-dev-community
S3_ACCESS_KEY_ID=replace-with-access-key
S3_SECRET_ACCESS_KEY=replace-with-secret-key
S3_PUBLIC_URL_BASE=http://localhost:9000/ai-dev-community
S3_FORCE_PATH_STYLE=true

# 공지 등 전체 회원 대상 알림 발송 시 배치 크기 (BullMQ 재귀 팬아웃)
NOTIFICATION_BROADCAST_BATCH_SIZE=500

SWAGGER_ENABLED=true
SWAGGER_PATH=docs

SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-this-before-seeding
